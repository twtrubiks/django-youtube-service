# Django settings
SECRET_KEY=change-me-to-a-random-secret-key
DEBUG=True

# Database
DB_NAME=postgres
DB_USER=myuser
DB_PASSWORD=password123
DB_HOST=django-postgres
DB_PORT=5432

# Redis
REDIS_HOST=redis-django

# Allowed Hosts (comma-separated)
ALLOWED_HOSTS=localhost,127.0.0.1

# CSRF Trusted Origins (comma-separated, required for production)
CSRF_TRUSTED_ORIGINS=

# Celery Worker concurrency (default: 2)
CELERY_CONCURRENCY=2

# S3/MinIO object storage (set USE_S3=true to enable)
USE_S3=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=streamcraft-media
AWS_S3_ENDPOINT_URL=
AWS_S3_REGION_NAME=us-east-1

# OpenTelemetry (leave empty to disable)
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=streamcraft
